# Copy this file to ".env" and fill in your Traeger app login.
# This is the SAME email + password you use in the Traeger phone app.
# The .env file is gitignored — chmod 600 .env after editing.
# Prefer Bitwarden or macOS Keychain; see SECURITY.md.
TRAEGER_USERNAME=you@example.com
TRAEGER_PASSWORD=your-traeger-password
